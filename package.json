{
  "name": "OrangeHRM",
  "version": "1.0.0",
  "description": "Enterprise-grade Playwright automation framework for OrangeHRM Demo",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "smoke": "playwright test --grep @smoke",
    "regression": "playwright test --grep @regression",
    "sanity": "playwright test --grep @sanity",
    "report": "playwright show-report report/playwright-report",
    "allure:generate": "allure generate allure-results -o report/allure-report --clean",
    "allure:open": "allure open report/allure-report",
    "allure:serve": "allure serve allure-results",
    "allure": "pnpm allure:generate && pnpm allure:open",
    "allure:check": "allure --version",
    "clean": "rm -rf test-results report/playwright-report report/allure-report allure-results report/k6-report report/k6-summary report/artifacts",
    "auth": "playwright test tests/playwright/tests/authentication/auth.setup.spec.ts",
    "k6:smoke": "K6_ENV=develop k6 run tests/k6/scripts/smoke.js --summary-export=report/k6-summary/summary.json --out json=report/k6-summary/metrics.json",
    "k6:load": "K6_ENV=develop k6 run tests/k6/scripts/load.js --summary-export=report/k6-summary/summary.json --out json=report/k6-summary/metrics.json",
    "k6:stress": "K6_ENV=develop k6 run tests/k6/scripts/stress.js --summary-export=report/k6-summary/summary.json --out json=report/k6-summary/metrics.json",
    "k6:soak": "K6_ENV=develop k6 run tests/k6/scripts/soak.js --summary-export=report/k6-summary/summary.json --out json=report/k6-summary/metrics.json",
    "k6:benchmark": "pnpm run k6:load",
    "k6:report": "cp tests/k6/reports/index.html report/k6-report/index.html && cp tests/k6/reports/index.html report/k6-summary/index.html",
    "k6:summary": "cat report/k6-summary/summary.json"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "allure-playwright": "^3.10.2"
  }
}